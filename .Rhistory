# ============================================================
# SCRIPT CLEANING DATA USAHA MAKASSAR
# ============================================================
# Masalah yang ditemukan di data:
#   1. Rating pakai koma (4,4) bukan titik (4.4) -> perlu konversi
#   2. Kecamatan salah parse: "gigi Mariso", "kecantikan Mamajang", dll
#   3. Duplikat nama usaha (231 baris)
#   4. NA di kategori_usaha (79), rating (71), ulasan (73), alamat (3)
#   5. website banyak kosong (1654) -> wajar, tidak perlu dihapus
#   6. foto_url kosong (4) -> wajar
# ============================================================
library(dplyr)
library(stringr)
library(readxl)
library(writexl)
library(tidyr)
# ── LOAD DATA ────────────────────────────────────────────────
cat("Loading data...\n")
df <- read_excel("data_usaha_makassar.xlsx")
cat(sprintf("Data awal: %d baris x %d kolom\n", nrow(df), ncol(df)))
# ============================================================
# STEP 1 — LAPORAN KONDISI AWAL
# ============================================================
cat("\n========================================\n")
cat("STEP 1: LAPORAN KONDISI AWAL\n")
cat("========================================\n")
cat("\n[NA per kolom]\n")
na_count <- colSums(is.na(df) | df == "" | df == "N/A" | df == "NaN", na.rm = TRUE)
for (col in names(na_count)) {
pct <- round(na_count[col] / nrow(df) * 100, 1)
cat(sprintf("  %-20s : %4d baris kosong (%.1f%%)\n", col, na_count[col], pct))
}
cat("\n[Duplikat]\n")
dup_nama_alamat <- sum(duplicated(df[, c("nama", "alamat")]))
dup_nama_saja   <- sum(duplicated(df$nama))
cat(sprintf("  Duplikat nama+alamat : %d baris\n", dup_nama_alamat))
cat(sprintf("  Duplikat nama saja   : %d baris (usaha sama beda keyword)\n", dup_nama_saja))
cat("\n[Kecamatan unik]\n")
print(sort(unique(df$kecamatan)))
# ============================================================
# STEP 2 — FIX KECAMATAN
# ============================================================
cat("\n========================================\n")
cat("STEP 2: FIX KECAMATAN\n")
cat("========================================\n")
# Daftar kecamatan yang valid
KECAMATAN_VALID <- c(
"Mariso", "Mamajang", "Tamalate", "Rappocini", "Makassar",
"Ujung Pandang", "Wajo", "Bontoala", "Ujung Tanah", "Tallo",
"Panakkukang", "Manggala", "Biringkanaya", "Tamalanrea",
"Kepulauan Sangkarrang"
)
# Ekstrak kecamatan yang benar dari kolom keyword
# Format keyword: "kategori kecamatan Makassar"
# Contoh: "klinik gigi Mariso Makassar" -> kecamatan = "Mariso"
fix_kecamatan <- function(kecamatan, keyword) {
# Kalau sudah valid, tidak perlu diubah
if (kecamatan %in% KECAMATAN_VALID) return(kecamatan)
# Cari kecamatan valid yang ada di dalam keyword
for (kec in KECAMATAN_VALID) {
if (str_detect(keyword, fixed(kec))) {
return(kec)
}
}
return(kecamatan)  # tetap sama kalau tidak ketemu
}
df$kecamatan_awal <- df$kecamatan  # backup
df$kecamatan <- mapply(fix_kecamatan, df$kecamatan, df$keyword)
n_fix_kec <- sum(df$kecamatan != df$kecamatan_awal)
cat(sprintf("  Kecamatan diperbaiki : %d baris\n", n_fix_kec))
cat("  Kecamatan setelah fix:\n")
print(sort(unique(df$kecamatan)))
df$kecamatan_awal <- NULL  # hapus kolom backup
# ============================================================
# STEP 3 — FIX RATING (koma -> titik)
# ============================================================
cat("\n========================================\n")
cat("STEP 3: FIX RATING\n")
cat("========================================\n")
df$rating_awal <- df$rating
df$rating <- as.numeric(str_replace(df$rating, ",", "."))
cat(sprintf("  Rating NA sebelum : %d\n", sum(is.na(df$rating_awal))))
cat(sprintf("  Rating NA sesudah : %d\n", sum(is.na(df$rating))))
cat(sprintf("  Range rating      : %.1f - %.1f\n",
min(df$rating, na.rm=TRUE), max(df$rating, na.rm=TRUE)))
df$rating_awal <- NULL
# ============================================================
# STEP 4 — BERSIHKAN NILAI KOSONG / TIDAK VALID
# ============================================================
cat("\n========================================\n")
cat("STEP 4: BERSIHKAN NILAI KOSONG\n")
cat("========================================\n")
# Ubah semua string kosong, "NaN", "N/A", "nan" -> NA
bersihkan_string <- function(x) {
if (is.character(x)) {
x[x %in% c("", "NaN", "N/A", "nan", "NULL", "None", "-")] <- NA
}
return(x)
}
df <- df %>% mutate(across(where(is.character), bersihkan_string))
# Laporan NA setelah cleaning
cat("  NA per kolom setelah cleaning:\n")
for (col in names(df)) {
n <- sum(is.na(df[[col]]))
if (n > 0) cat(sprintf("    %-20s : %d\n", col, n))
}
# ============================================================
# STEP 5 — HAPUS DUPLIKAT
# ============================================================
cat("\n========================================\n")
cat("STEP 5: HAPUS DUPLIKAT\n")
cat("========================================\n")
n_sebelum <- nrow(df)
# Strategi duplikat:
# - Usaha yang sama muncul dari keyword berbeda = KEEP yang rating lebih tinggi
# - Duplikat persis (nama + alamat) = hapus
df <- df %>%
arrange(nama, desc(rating), desc(jumlah_ulasan)) %>%
distinct(nama, alamat, .keep_all = TRUE)
n_sesudah <- nrow(df)
cat(sprintf("  Baris sebelum : %d\n", n_sebelum))
cat(sprintf("  Baris sesudah : %d\n", n_sesudah))
cat(sprintf("  Dihapus       : %d baris duplikat\n", n_sebelum - n_sesudah))
# ============================================================
# STEP 6 — HAPUS BARIS KRITIS YANG KOSONG
# ============================================================
cat("\n========================================\n")
cat("STEP 6: HAPUS BARIS TANPA DATA KRITIS\n")
cat("========================================\n")
n_sebelum <- nrow(df)
# Hapus hanya yang kolom KRITIS kosong (nama & kecamatan wajib ada)
df <- df %>%
filter(!is.na(nama)) %>%
filter(!is.na(kecamatan)) %>%
filter(kecamatan %in% KECAMATAN_VALID)  # pastikan kecamatan valid
n_sesudah <- nrow(df)
cat(sprintf("  Dihapus baris tanpa nama/kecamatan valid: %d\n", n_sebelum - n_sesudah))
# ============================================================
# STEP 7 — NORMALISASI & TAMBAH KOLOM TURUNAN
# ============================================================
cat("\n========================================\n")
cat("STEP 7: NORMALISASI & KOLOM TURUNAN\n")
cat("========================================\n")
# Bersihkan spasi berlebih
df <- df %>%
mutate(
nama           = str_squish(nama),
alamat         = str_squish(alamat),
kategori_usaha = str_squish(kategori_usaha)
)
# Normalisasi jumlah ulasan (hapus tanda titik ribuan jika ada)
df$jumlah_ulasan <- as.numeric(df$jumlah_ulasan)
# Tambah kolom kategori_grup (pengelompokan besar)
df <- df %>%
mutate(
kategori_grup = case_when(
str_detect(tolower(kategori_usaha),
"kafe|coffee|kopi|restoran|makan|seafood|bakso|mie|soto|sate|nasi|burger|pizza|korean|dessert|es |roti|donat|warung|kuliner|makanan|minuman|jus|boba") ~ "Kuliner & Minuman",
str_detect(tolower(kategori_usaha),
"minimarket|supermarket|toko|retail|pakaian|sepatu|tas|buku|mainan|kosmetik|aksesoris|elektronik|hp|komputer|furnitur|bangunan|kelontong") ~ "Retail & Toko",
str_detect(tolower(kategori_usaha),
"apotek|klinik|dokter|rumah sakit|puskesmas|optik|kesehatan|medis|farmasi|laboratorium") ~ "Kesehatan",
str_detect(tolower(kategori_usaha),
"salon|barbershop|cukur|kecantikan|spa|nail|perawatan|rambut") ~ "Kecantikan",
str_detect(tolower(kategori_usaha),
"bengkel|cuci motor|cuci mobil|tambal|sparepart|otomotif|ban|servis kendaraan") ~ "Otomotif",
str_detect(tolower(kategori_usaha),
"laundry|cuci|percetakan|foto|print|studio|jasa|servis hp|jahit|ekspedisi|travel") ~ "Jasa Umum",
str_detect(tolower(kategori_usaha),
"bimbel|kursus|les|sekolah|pendidikan|tk |sd |smp |sma") ~ "Pendidikan",
str_detect(tolower(kategori_usaha),
"gym|fitness|futsal|kolam renang|olahraga|karaoke|hiburan|bioskop") ~ "Hiburan & Olahraga",
str_detect(tolower(kategori_usaha),
"hotel|penginapan|kost|guest house|villa|resort|losmen") ~ "Akomodasi",
TRUE ~ "Lainnya"
)
)
cat("  Distribusi kategori_grup:\n")
tbl <- sort(table(df$kategori_grup), decreasing=TRUE)
for (i in seq_along(tbl)) {
cat(sprintf("    %-25s : %d\n", names(tbl)[i], tbl[i]))
}
# Tambah kolom rating_kategori
df <- df %>%
mutate(
rating_kategori = case_when(
rating >= 4.5 ~ "Sangat Baik",
rating >= 4.0 ~ "Baik",
rating >= 3.5 ~ "Cukup",
rating >= 3.0 ~ "Kurang",
!is.na(rating) ~ "Buruk",
TRUE ~ NA_character_
)
)
# Tambah kolom popularitas berdasarkan jumlah ulasan
df <- df %>%
mutate(
popularitas = case_when(
jumlah_ulasan >= 500  ~ "Sangat Populer",
jumlah_ulasan >= 100  ~ "Populer",
jumlah_ulasan >= 20   ~ "Cukup Dikenal",
jumlah_ulasan >= 1    ~ "Baru",
TRUE ~ NA_character_
)
)
# ============================================================
# STEP 8 — IMPUTASI NILAI KOSONG (yang bisa diisi)
# ============================================================
cat("\n========================================\n")
cat("STEP 8: IMPUTASI NILAI KOSONG\n")
cat("========================================\n")
# Rating kosong -> isi dengan median per kategori_grup
median_rating <- df %>%
filter(!is.na(rating)) %>%
group_by(kategori_grup) %>%
summarise(median_r = median(rating, na.rm=TRUE), .groups="drop")
n_rating_na <- sum(is.na(df$rating))
df <- df %>%
left_join(median_rating, by="kategori_grup") %>%
mutate(
rating_imputasi = is.na(rating),
rating = ifelse(is.na(rating), median_r, rating)
) %>%
select(-median_r)
cat(sprintf("  Rating diimputasi (median per kategori): %d baris\n", n_rating_na))
# Ulasan kosong -> isi 0
n_ulasan_na <- sum(is.na(df$jumlah_ulasan))
df$jumlah_ulasan[is.na(df$jumlah_ulasan)] <- 0
cat(sprintf("  Jumlah ulasan NA diisi 0: %d baris\n", n_ulasan_na))
# kategori_usaha kosong -> isi "Tidak Diketahui"
n_kat_na <- sum(is.na(df$kategori_usaha))
df$kategori_usaha[is.na(df$kategori_usaha)] <- "Tidak Diketahui"
cat(sprintf("  Kategori usaha NA diisi 'Tidak Diketahui': %d baris\n", n_kat_na))
# ============================================================
# STEP 9 — VALIDASI AKHIR
# ============================================================
cat("\n========================================\n")
cat("STEP 9: VALIDASI AKHIR\n")
cat("========================================\n")
# Cek range rating
cat(sprintf("  Rating range   : %.1f - %.1f\n",
min(df$rating, na.rm=TRUE), max(df$rating, na.rm=TRUE)))
# Rating outlier (< 1 atau > 5)
n_outlier <- sum(df$rating < 1 | df$rating > 5, na.rm=TRUE)
cat(sprintf("  Rating outlier (< 1 atau > 5): %d\n", n_outlier))
if (n_outlier > 0) {
df <- df %>% filter(rating >= 1 & rating <= 5)
cat("  -> Outlier dihapus\n")
}
# Duplikat final
n_dup_final <- sum(duplicated(df[, c("nama", "alamat")]))
cat(sprintf("  Duplikat final : %d\n", n_dup_final))
# Summary kolom penting
cat("\n  NA final per kolom:\n")
for (col in c("nama","kategori_usaha","rating","jumlah_ulasan","alamat","kecamatan","foto_url")) {
n <- sum(is.na(df[[col]]))
cat(sprintf("    %-20s : %d\n", col, n))
}
# ============================================================
# STEP 10 — RAPIKAN KOLOM & SIMPAN
# ============================================================
cat("\n========================================\n")
cat("STEP 10: SIMPAN OUTPUT\n")
cat("========================================\n")
# Urutan kolom yang rapi
df_clean <- df %>%
select(
# Identitas
nama, kategori_usaha, kategori_grup,
# Lokasi
kecamatan, alamat,
# Metrik
rating, rating_kategori, rating_imputasi,
jumlah_ulasan, popularitas,
# Kontak
telepon, website,
# Media
foto_url,
# Metadata
keyword, tanggal
) %>%
arrange(kecamatan, kategori_grup, desc(rating), desc(jumlah_ulasan))
# Simpan versi clean
write_xlsx(df_clean, "data_usaha_makassar_clean.xlsx")
write.csv(df_clean, "data_usaha_makassar_clean.csv", row.names=FALSE, fileEncoding="UTF-8")
cat(sprintf("\n  Data clean disimpan:\n"))
cat(sprintf("    data_usaha_makassar_clean.xlsx\n"))
cat(sprintf("    data_usaha_makassar_clean.csv\n"))
# ============================================================
# LAPORAN AKHIR
# ============================================================
cat("\n========================================\n")
cat("LAPORAN AKHIR\n")
cat("========================================\n")
cat(sprintf("  Baris awal         : 2296\n"))
cat(sprintf("  Baris akhir        : %d\n", nrow(df_clean)))
cat(sprintf("  Baris dihapus      : %d\n", 2296 - nrow(df_clean)))
cat(sprintf("  Kolom              : %d\n", ncol(df_clean)))
cat(sprintf("\n  Distribusi kecamatan:\n"))
kec_tbl <- sort(table(df_clean$kecamatan), decreasing=TRUE)
for (i in seq_along(kec_tbl)) {
cat(sprintf("    %-25s : %d\n", names(kec_tbl)[i], kec_tbl[i]))
}
cat(sprintf("\n  Distribusi kategori_grup:\n"))
kat_tbl <- sort(table(df_clean$kategori_grup), decreasing=TRUE)
for (i in seq_along(kat_tbl)) {
cat(sprintf("    %-25s : %d\n", names(kat_tbl)[i], kat_tbl[i]))
}
cat(sprintf("\n  Avg rating         : %.2f\n", mean(df_clean$rating, na.rm=TRUE)))
cat(sprintf("  Median ulasan      : %.0f\n", median(df_clean$jumlah_ulasan, na.rm=TRUE)))
cat(sprintf("  Ada foto           : %d (%.1f%%)\n",
sum(!is.na(df_clean$foto_url)),
sum(!is.na(df_clean$foto_url))/nrow(df_clean)*100))
cat("\nSelesai!\n")
# ============================================================
# CLEANING DATA USAHA MAKASSAR
# ============================================================
library(dplyr); library(stringr); library(readxl)
library(writexl); library(scales)
cat("=== CLEANING DATA USAHA MAKASSAR ===\n\n")
df <- read_excel("data_usaha_makassar.xlsx")
cat(sprintf("Awal: %d baris x %d kolom\n", nrow(df), ncol(df)))
# 1. RENAME kolom Latitude/Longitude -> lowercase
if("Latitude"  %in% names(df)) { df$latitude  <- df$Latitude;  df$Latitude  <- NULL }
if("Longitude" %in% names(df)) { df$longitude <- df$Longitude; df$Longitude <- NULL }
# 2. FIX TIPE KOLOM
df$latitude      <- as.numeric(df$latitude)
df$longitude     <- as.numeric(df$longitude)
df$rating        <- as.numeric(str_replace(as.character(df$rating), ",", "."))
df$jumlah_ulasan <- as.numeric(df$jumlah_ulasan)
df$jumlah_ulasan[is.na(df$jumlah_ulasan)] <- 0
cat(sprintf("[1] Rating range: %.1f - %.1f\n", min(df$rating,na.rm=TRUE), max(df$rating,na.rm=TRUE)))
# 3. FIX KOORDINAT (titik desimal hilang)
fix_lat <- function(v) {
if(is.na(v)) return(NA_real_)
for(d in c(1,10,100,1000,10000,100000,1000000,10000000,1e15)) {
r <- v/d
if(!is.na(r) && r >= -5.30 && r <= -5.00) return(round(r,7))
}; NA_real_
}
fix_lng <- function(v) {
if(is.na(v)) return(NA_real_)
for(d in c(1,10,100,1000,10000,100000,1000000,10000000,1e8)) {
r <- v/d
if(!is.na(r) && r >= 119.20 && r <= 119.60) return(round(r,7))
}; NA_real_
}
df$latitude  <- sapply(df$latitude,  fix_lat)
df$longitude <- sapply(df$longitude, fix_lng)
cat(sprintf("[2] Koordinat valid: %d / %d\n",
sum(!is.na(df$latitude)&!is.na(df$longitude)), nrow(df)))
# 4. FIX KECAMATAN
KECS <- c("Mariso","Mamajang","Tamalate","Rappocini","Makassar",
"Ujung Pandang","Wajo","Bontoala","Ujung Tanah","Tallo",
"Panakkukang","Manggala","Biringkanaya","Tamalanrea","Kepulauan Sangkarrang")
fix_kec <- function(kec, kw) {
if(kec %in% KECS) return(kec)
for(k in KECS) if(str_detect(kw, fixed(k))) return(k)
return(kec)
}
df$kecamatan <- mapply(fix_kec, df$kecamatan, df$keyword)
n_invalid <- sum(!df$kecamatan %in% KECS)
if(n_invalid > 0) df <- df %>% filter(kecamatan %in% KECS)
cat(sprintf("[3] Kecamatan fix: %s\n", paste(sort(unique(df$kecamatan)), collapse=", ")))
# 5. BERSIHKAN STRING
bersih <- function(x) { if(is.character(x)) x[x %in% c("","NaN","N/A","nan","NULL","None","-")] <- NA; x }
df <- df %>% mutate(across(where(is.character), bersih))
# 6. IMPUTASI
df$kategori_usaha[is.na(df$kategori_usaha)] <- "Tidak Diketahui"
df$rating[is.na(df$rating)] <- median(df$rating, na.rm=TRUE)
cat(sprintf("[4] Rating NA diisi median: %.2f\n", median(df$rating, na.rm=TRUE)))
# 7. HAPUS DUPLIKAT (keep rating tertinggi)
n_bfr <- nrow(df)
df <- df %>% arrange(nama, desc(rating), desc(jumlah_ulasan)) %>%
distinct(nama, alamat, .keep_all=TRUE)
cat(sprintf("[5] Duplikat dihapus: %d baris\n", n_bfr - nrow(df)))
# 8. HAPUS RATING OUTLIER
df <- df %>% filter(rating >= 1 & rating <= 5)
# 9. TAMBAH KOLOM TURUNAN
df <- df %>% mutate(
kategori_grup = case_when(
str_detect(tolower(kategori_usaha),
"kafe|coffee|kopi|restoran|makan|seafood|bakso|mie|soto|sate|nasi|burger|pizza|korean|japanese|chinese|dessert|es |roti|donat|warung|kuliner|minuman|jus|boba|pisang|coto|konro|pallubasa|kapurung|jalangkote|martabak|geprek|ayam") ~ "Kuliner & Minuman",
str_detect(tolower(kategori_usaha),
"minimarket|supermarket|toko|retail|pakaian|sepatu|tas|buku|mainan|kosmetik|aksesoris|elektronik|komputer|furnitur|bangunan|kelontong|oleh") ~ "Retail & Toko",
str_detect(tolower(kategori_usaha),
"apotek|klinik|dokter|rumah sakit|puskesmas|optik|kesehatan|medis|farmasi") ~ "Kesehatan",
str_detect(tolower(kategori_usaha),
"salon|barbershop|cukur|kecantikan|spa|nail|perawatan|rambut") ~ "Kecantikan",
str_detect(tolower(kategori_usaha),
"bengkel|cuci motor|cuci mobil|tambal|sparepart|otomotif|ban|modifikasi") ~ "Otomotif",
str_detect(tolower(kategori_usaha),
"laundry|cuci|percetakan|foto studio|print|jasa|servis|jahit|ekspedisi|travel|notaris") ~ "Jasa Umum",
str_detect(tolower(kategori_usaha),
"bimbel|kursus|les|sekolah|pendidikan") ~ "Pendidikan",
str_detect(tolower(kategori_usaha),
"gym|fitness|futsal|kolam|olahraga|karaoke|hiburan|bioskop") ~ "Hiburan & Olahraga",
str_detect(tolower(kategori_usaha),
"hotel|penginapan|kost|guest house|villa|resort") ~ "Akomodasi",
TRUE ~ "Lainnya"
),
rating_kategori = case_when(
rating>=4.5~"Sangat Baik", rating>=4.0~"Baik",
rating>=3.5~"Cukup",       rating>=3.0~"Kurang",
!is.na(rating)~"Buruk",    TRUE~NA_character_
),
popularitas = case_when(
jumlah_ulasan>=500~"Sangat Populer", jumlah_ulasan>=100~"Populer",
jumlah_ulasan>=20~"Cukup Dikenal",   jumlah_ulasan>=1~"Baru",
TRUE~"Tidak Ada Ulasan"
),
skor_potensi = round(
rescale(rating, to=c(0,100), from=c(1,5)) * 0.6 +
rescale(log1p(jumlah_ulasan), to=c(0,100)) * 0.4, 1
),
label_kelayakan = case_when(
skor_potensi>=75~"Sangat Layak", skor_potensi>=55~"Layak",
skor_potensi>=35~"Cukup Layak",  TRUE~"Kurang Layak"
)
)
cat(sprintf("[6] Kolom turunan ditambahkan\n"))
# 10. RAPIKAN & SIMPAN
df_clean <- df %>%
select(nama, kategori_usaha, kategori_grup, kecamatan, alamat,
rating, rating_kategori, jumlah_ulasan, popularitas,
skor_potensi, label_kelayakan, latitude, longitude,
telepon, website, foto_url, keyword, tanggal) %>%
arrange(kecamatan, kategori_grup, desc(skor_potensi))
write_xlsx(df_clean, "data_usaha_makassar_clean.xlsx")
write.csv(df_clean, "data_usaha_makassar_clean.csv", row.names=FALSE, fileEncoding="UTF-8")
cat(sprintf("\n=== HASIL ===\n"))
cat(sprintf("Baris final    : %d\n", nrow(df_clean)))
cat(sprintf("Koordinat valid: %d (%.1f%%)\n",
sum(!is.na(df_clean$latitude)), sum(!is.na(df_clean$latitude))/nrow(df_clean)*100))
cat(sprintf("Avg rating     : %.2f\n", mean(df_clean$rating,na.rm=TRUE)))
cat(sprintf("Avg potensi    : %.1f\n", mean(df_clean$skor_potensi,na.rm=TRUE)))
cat(sprintf("\nKecamatan:\n"))
print(sort(table(df_clean$kecamatan),decreasing=TRUE))
cat(sprintf("\nKategori grup:\n"))
print(sort(table(df_clean$kategori_grup),decreasing=TRUE))
cat("\nFile: data_usaha_makassar_clean.xlsx & .csv\nSelesai!\n")
library(shiny); runApp('app2.R')
